# Umami analytics credentials for LaserKerf (self-hosted fork).
# Copy to `.env` in this folder (gitignored) and fill in USERNAME/PASSWORD.
# Used by umami.mjs to log in and refresh the cached JWT when it expires.
UMAMI_BASE_URL=https://analytics.mjmiller.cloud
UMAMI_WEBSITE_ID=c835d982-8f88-4cc3-8b11-d62778c789ff
UMAMI_USERNAME=
UMAMI_PASSWORD=
# Where the refreshed token JSON is written (default shown):
UMAMI_TOKEN_FILE=/home/michael/Code/analytics-mjmiller-cloud-token.json
