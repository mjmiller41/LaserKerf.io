{
  "name": "fileformats",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Project storage (OPFS blobs + IndexedDB metadata), crash-safe autosave, and (later) .laserkerf/.lbrn/import-export codecs.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:golden": "vitest run golden",
    "test:coordinate": "vitest run coordinate"
  },
  "dependencies": {
    "cam": "workspace:*",
    "fflate": "^0.8.2",
    "idb": "^8.0.3",
    "opentype.js": "^1.3.4",
    "scene": "workspace:*"
  },
  "devDependencies": {
    "@types/opentype.js": "^1.3.8",
    "fake-indexeddb": "^6.2.5",
    "golden": "workspace:*",
    "jsdom": "^29.1.1"
  }
}
