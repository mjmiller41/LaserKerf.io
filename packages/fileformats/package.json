{
  "name": "fileformats",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Project storage (OPFS blobs + IndexedDB metadata), crash-safe autosave, and (later) .fluence/.lbrn/import-export codecs.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:golden": "vitest run golden",
    "test:coordinate": "vitest run coordinate"
  },
  "dependencies": {
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "golden": "workspace:*"
  }
}
