{
  "name": "geometry-wasm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Clipper2 (C++ -> WASM) boolean/offset geometry, exposed to the app through a Comlink worker so all heavy compute stays off the main thread (CLAUDE.md invariant 4).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "node tools/prepare-wasm.mjs",
    "build:wasm": "bash tools/build-clipper2.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "clipper2-wasm": "^0.4.0",
    "comlink": "^4.4.2"
  },
  "devDependencies": {
    "@types/emscripten": "^1.40.1",
    "@vitest/web-worker": "^4.1.9",
    "golden": "workspace:*"
  }
}
